Ć<Application x:Class="GeminiLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:GeminiLauncher.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                
                <!-- Language Resources (Default: English) -->
                <ResourceDictionary Source="Resources/Languages/en-US.xaml"/>
                
                <!-- iOS 26 Styles -->
                <ResourceDictionary Source="Styles/iOS26.xaml"/>
                <ResourceDictionary Source="Styles/GlassScrollBar.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Mint Green Theme Overrides -->
            <Color x:Key="SystemAccentColor">#00E676</Color>
            <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{StaticResource SystemAccentColor}"/>
            <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource SystemAccentColor}"/>
            <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="#00C853"/>
            <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="#69F0AE"/>
            
            <!-- Global Text Override for Dark Glass Theme -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="White"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#CCFFFFFF"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#80FFFFFF"/>
            
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>
            
            <!-- Glass Card Style -->
            <Style TargetType="{x:Type ui:Card}">
                <Setter Property="Background" Value="#20000000" /> <!-- More transparent for background image -->
                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <!-- Glass Button Style -->
            <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BorderBrush" Value="#30FFFFFF" />
                <Setter Property="Background" Value="#20FFFFFF" />
                <Setter Property="Foreground" Value="White" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#40FFFFFF" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Navigation Item Style -->
            <Style TargetType="{x:Type ui:NavigationViewItem}">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Margin" Value="0,2" />
            </Style>
            
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:StringMatchToBoolConverter x:Key="StringMatchToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
