<Page x:Class="GeminiLauncher.Views.VersionSelectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Version Selector">

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="50" To="0" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>
    
    <Page.RenderTransform>
        <TranslateTransform/>
    </Page.RenderTransform>

    <Border Background="{StaticResource iOS26.ContentLayer}" CornerRadius="36" Margin="20">
        <Border.Effect><DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="Black"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#30FFFFFF">
                <Grid.Clip>
                    <RectangleGeometry Rect="0,0,10000,60" RadiusX="36" RadiusY="36"/>
                </Grid.Clip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="&#x2190;" Width="45" Height="45" Margin="10,0,0,0"
                        FontSize="24" Background="Transparent" Foreground="White" BorderThickness="0"
                        Click="BackButton_Click" Cursor="Hand" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" Text="{DynamicResource VersionSelector_Title}" FontSize="20" FontWeight="SemiBold" Foreground="White" 
                           VerticalAlignment="Center" Margin="10,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button x:Name="ToggleFolderBtn" Content="📂" 
                            Click="ToggleFolderPanel_Click" 
                            Width="45" Height="45" FontSize="20"
                            Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                            Background="Transparent" Foreground="White" 
                            BorderThickness="0" Cursor="Hand"
                            ToolTip="{DynamicResource VersionSelector_ToggleFolderTooltip}">
                         <Button.Resources>
                             <Style TargetType="Button">
                                 <Setter Property="Template">
                                     <Setter.Value>
                                         <ControlTemplate TargetType="Button">
                                             <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                 <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                             </Border>
                                             <ControlTemplate.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                                                 </Trigger>
                                                 <Trigger Property="IsPressed" Value="True">
                                                     <Setter TargetName="border" Property="Background" Value="#40FFFFFF"/>
                                                 </Trigger>
                                             </ControlTemplate.Triggers>
                                         </ControlTemplate>
                                     </Setter.Value>
                                 </Setter>
                             </Style>
                         </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Folder Panel -->
                <Border x:Name="FolderPanel" Grid.Column="0" Width="220" Background="#20FFFFFF" CornerRadius="24" Padding="10" Margin="0,0,20,0" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{DynamicResource VersionSelector_FolderListHeader}" FontSize="12" Opacity="0.7" Margin="5,5,5,10" Foreground="White"/>
                        <ListView x:Name="FoldersListView" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="FoldersListView_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="{Binding Path}" FontSize="10" Opacity="0.6" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                            <Button Content="{DynamicResource VersionSelector_AddFolder}" Click="AddFolder_Click" Padding="10,8" Background="#30FFFFFF" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,5"/>
                             <!-- Removed Import Modpack for now as it's not implemented -->
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Version List -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="VersionsPanel" Margin="0,0,10,0"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Page>