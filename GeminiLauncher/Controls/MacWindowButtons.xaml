<UserControl x:Class="GeminiLauncher.Controls.MacWindowButtons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="32" d:DesignWidth="80">
    <StackPanel Orientation="Horizontal" Margin="12,0">
        <!-- Close Button (Red) -->
        <Button x:Name="CloseButton" 
                Width="14" Height="14" 
                Margin="0,0,8,0"
                Cursor="Hand"
                Click="CloseButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#FF5F56"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="{TemplateBinding Background}" 
                                         Width="14" Height="14">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" 
                                                        ShadowDepth="1" 
                                                        Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF7A6E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Minimize Button (Yellow) -->
        <Button x:Name="MinimizeButton" 
                Width="14" Height="14" 
                Margin="0,0,8,0"
                Cursor="Hand"
                Click="MinimizeButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#FFBD2E"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="{TemplateBinding Background}" 
                                         Width="14" Height="14">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" 
                                                        ShadowDepth="1" 
                                                        Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFD04A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <!-- Maximize Button (Green) -->
        <Button x:Name="MaximizeButton" 
                Width="14" Height="14"
                Cursor="Hand"
                Click="MaximizeButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#27C93F"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Ellipse Fill="{TemplateBinding Background}" 
                                         Width="14" Height="14">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" 
                                                        ShadowDepth="1" 
                                                        Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3FDE55"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </StackPanel>
</UserControl>
