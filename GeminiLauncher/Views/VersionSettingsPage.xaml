<Page x:Class="GeminiLauncher.Views.VersionSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Version Settings">

    <Page.Resources>
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                         <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                             <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}"/>
                         </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#40FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="50" To="0" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Page.Triggers>
    
    <Page.RenderTransform>
        <TranslateTransform/>
    </Page.RenderTransform>

    <Border Background="{StaticResource iOS26.ContentLayer}" CornerRadius="36" Margin="20">
        <Border.Effect><DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="Black"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Height="60" Background="#30FFFFFF">
                <!-- Make sure the top row background conforms to the 36 radius border -->
                <Grid.Clip>
                    <RectangleGeometry Rect="0,0,10000,60" RadiusX="36" RadiusY="36"/>
                </Grid.Clip>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Grid.Column="0" Content="←" Width="45" Height="45" Margin="10,0,0,0"
                        FontSize="24" Background="Transparent" Foreground="White" BorderThickness="0"
                        Click="BackButton_Click" Cursor="Hand" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="TitleText" Text="版本设置" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="SubtitleText" Text="Loading..." FontSize="12" Opacity="0.6" Foreground="White"/>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Tab Navigation -->
                <Border Grid.Column="0" Background="#20FFFFFF" CornerRadius="24" Margin="10,0,0,10" Padding="15">
                    <StackPanel>
                        <Button x:Name="TabOverview" Content="📦 概览" Click="TabButton_Click" Tag="overview"
                                Style="{StaticResource TabButtonStyle}" IsEnabled="False"/>
                        <Button x:Name="TabSettings" Content="⚙️ 设置" Click="TabButton_Click" Tag="settings"
                                Style="{StaticResource TabButtonStyle}"/>
                        <Button x:Name="TabMods" Content="🧩 Mod管理" Click="TabButton_Click" Tag="mods"
                                Style="{StaticResource TabButtonStyle}"/>
                        <Button x:Name="TabExport" Content="📤 导出" Click="TabButton_Click" Tag="export"
                                Style="{StaticResource TabButtonStyle}"/>
                        <Button x:Name="TabMaintenance" Content="🛠️ 维护" Click="TabButton_Click" Tag="maintenance"
                                Style="{StaticResource TabButtonStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Right Content Area -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="20">
                    <Grid x:Name="ContentArea">
                        <!-- Content will be loaded dynamically -->
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Page>
