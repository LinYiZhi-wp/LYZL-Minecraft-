                            <Border Width="90" Height="11" CornerRadius="4" Background="#252530" Margin="0,8,0,0"/>
                            <Border Width="55" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="70" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="180" Height="24" CornerRadius="8" Background="#252530" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Width="180" CornerRadius="14" Background="#1A1A24" Margin="0,0,10,14">
                        <Border.Triggers><EventTrigger RoutedEvent="Border.Loaded"><BeginStoryboard Storyboard="{StaticResource SkeletonPulse}"/></EventTrigger></Border.Triggers>
                        <StackPanel Margin="10">
                            <Border Height="60" CornerRadius="10" Background="#252530"/>
                            <Border Width="90" Height="11" CornerRadius="4" Background="#252530" Margin="0,8,0,0"/>
                            <Border Width="55" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="70" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="180" Height="24" CornerRadius="8" Background="#252530" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Width="180" CornerRadius="14" Background="#1A1A24" Margin="0,0,10,14">
                        <Border.Triggers><EventTrigger RoutedEvent="Border.Loaded"><BeginStoryboard Storyboard="{StaticResource SkeletonPulse}"/></EventTrigger></Border.Triggers>
                        <StackPanel Margin="10">
                            <Border Height="60" CornerRadius="10" Background="#252530"/>
                            <Border Width="90" Height="11" CornerRadius="4" Background="#252530" Margin="0,8,0,0"/>
                            <Border Width="55" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="70" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="180" Height="24" CornerRadius="8" Background="#252530" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Width="180" CornerRadius="14" Background="#1A1A24" Margin="0,0,10,14">
                        <Border.Triggers><EventTrigger RoutedEvent="Border.Loaded"><BeginStoryboard Storyboard="{StaticResource SkeletonPulse}"/></EventTrigger></Border.Triggers>
                        <StackPanel Margin="10">
                            <Border Height="60" CornerRadius="10" Background="#252530"/>
                            <Border Width="90" Height="11" CornerRadius="4" Background="#252530" Margin="0,8,0,0"/>
                            <Border Width="55" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="70" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="180" Height="24" CornerRadius="8" Background="#252530" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Width="180" CornerRadius="14" Background="#1A1A24" Margin="0,0,10,14">
                        <Border.Triggers><EventTrigger RoutedEvent="Border.Loaded"><BeginStoryboard Storyboard="{StaticResource SkeletonPulse}"/></EventTrigger></Border.Triggers>
                        <StackPanel Margin="10">
                            <Border Height="60" CornerRadius="10" Background="#252530"/>
                            <Border Width="90" Height="11" CornerRadius="4" Background="#252530" Margin="0,8,0,0"/>
                            <Border Width="55" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="70" Height="7" CornerRadius="4" Background="#252530" Margin="0,5,0,0"/>
                            <Border Width="180" Height="24" CornerRadius="8" Background="#252530" Margin="0,7,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- RESULTS LISTBOX - 直接放Grid内，VirtualizingPanel自己管理滚动 -->
                <ItemsControl ItemsSource="{Binding SearchResults}"
                             Visibility="{Binding HasSearchResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ResourceCard}" Width="180" Margin="0,0,10,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="60"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="14,14,0,0" ClipToBounds="True">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding IconImage}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                        <Border Background="#18000000"/>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="8,6,8,8">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" Foreground="White" TextTrimming="CharacterEllipsis" Margin="0,0,0,1"/>
                                        <TextBlock Text="{Binding Author}" FontSize="9" Foreground="#70FFFFFF" TextTrimming="CharacterEllipsis" Margin="0,0,0,1"/>
                                        <TextBlock Text="{Binding Downloads, Converter={StaticResource DownloadCountConverter}}" FontSize="9" Foreground="#00E676" Margin="0,0,0,5"/>
                                        <ui:Button Content="⬇"
                                                   Command="{Binding DataContext.DownloadModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   Appearance="Primary"
                                                   HorizontalAlignment="Stretch"
                                                   Padding="0,3"
                                                   FontSize="10"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- EMPTY STATE -->
                <StackPanel Visibility="{Binding IsSearchEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Search48" FontSize="48" Foreground="#40FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="没有找到相关资源" FontSize="15" Foreground="#80FFFFFF"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="试试其他关键词或分类" FontSize="12" Foreground="#50FFFFFF"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- LOAD MORE -->
                <Button Command="{Binding LoadMoreCommand}" Margin="0,8,0,0"
                        Background="#12FFFFFF" Foreground="White" HorizontalAlignment="Center"
                        BorderThickness="0" Cursor="Hand" Padding="24,10"
                        Visibility="{Binding HasSearchResults, Converter={StaticResource BooleanToVisibilityConverter}}"
                        VerticalAlignment="Bottom">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="加载更多" FontSize="13" Foreground="#B0FFFFFF" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1EFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
