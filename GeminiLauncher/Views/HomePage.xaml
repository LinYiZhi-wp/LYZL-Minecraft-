<Page x:Class="GeminiLauncher.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:GeminiLauncher.Views"
      xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Home"
      Background="Transparent">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,0,0">
            <Grid Margin="24,24,16,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="GreetingText" Text="👋 你好，Player"
                               FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="准备好开始冒险了吗？" FontSize="14" Foreground="#B0FFFFFF" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Right"
                        CornerRadius="22"
                        Background="{StaticResource iOS26.FloatingLayer}"
                        BorderBrush="#20FFFFFF"
                        BorderThickness="1"
                        Padding="14,8"
                        Cursor="Hand"
                        MouseLeftButtonDown="AccountCapsule_Click"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="AccountScale"/>
                    </Border.RenderTransform>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34" CornerRadius="17" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00E676" Offset="0"/>
                                    <GradientStop Color="#00C853" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="👤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="PlayerNameText" Text="Player" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock x:Name="PlayerModeText" Text="离线模式" FontSize="10" Opacity="0.5" Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="▼" FontSize="9" VerticalAlignment="Center" Foreground="White" Opacity="0.5"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource iOS26.GlassCard}" Margin="0,0,0,24" Padding="28,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="VersionHeroText" Text="LYZL"
                                   FontSize="36" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="CurrentVersionSubtitle"
                                   Text="{DynamicResource Home_NoVersionSelected}"
                                   FontSize="14" Foreground="#B0FFFFFF" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                        <Button x:Name="LaunchButton"
                                Command="{Binding LaunchGameCommand}"
                                Content="🚀 启动游戏"
                                Height="52" FontSize="18" FontWeight="Bold"
                                Foreground="White" Cursor="Hand" Margin="0,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Height="{TemplateBinding Height}" CornerRadius="26" RenderTransformOrigin="0.5,0.5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#2ECC71" Offset="0"/>
                                                            <GradientStop Color="#00E676" Offset="0.5"/>
                                                            <GradientStop Color="#00C853" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.RenderTransform>
                                                        <ScaleTransform x:Name="ButtonScale"/>
                                                    </Border.RenderTransform>
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="28,0"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#5CFF9A" Offset="0"/>
                                                                    <GradientStop Color="#00FF80" Offset="0.5"/>
                                                                    <GradientStop Color="#00E676" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.2">
                                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.2">
                                                                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.2">
                                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.2">
                                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.06"/>
                                                                    <DoubleAnimation Storyboard.TargetName="ButtonScale" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.06"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Visibility>
                                <Binding Path="IsLaunching" Converter="{StaticResource InverseBooleanToVisibilityConverter}"/>
                            </Button.Visibility>
                        </Button>

                        <Border x:Name="LaunchProgressPanel" Background="{StaticResource iOS26.ContentLayer}" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="26" Height="52" Margin="0,0,0,0">
                            <Border.Visibility>
                                <Binding Path="IsLaunching" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                            </Border.Visibility>
                            <Grid>
                                <ProgressBar x:Name="LaunchProgressBar" VerticalAlignment="Bottom" Height="3" Background="Transparent" Foreground="#00E676" BorderThickness="0" IsIndeterminate="True" Margin="16,0,16,10"/>
                                <TextBlock x:Name="LaunchStatusText" Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="{DynamicResource Home_SelectVersion}" Style="{StaticResource iOS26.CapsuleButton}" Click="OpenVersionSelector_Click" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource Home_VersionSettings}" Style="{StaticResource iOS26.CapsuleButton}" Click="OpenVersionSettings_Click" Margin="0,0,8,0"/>
                        <Button Content="🧩" Height="40" Width="46" Click="OpenModManager_Click" ToolTip="{DynamicResource Home_ModManagerTooltip}" Style="{StaticResource iOS26.CapsuleButton}" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="快速概览" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>

            <UniformGrid Grid.Row="3" Columns="4" Margin="0,0,0,24">
                <Border Style="{StaticResource iOS26.GlassCard}" Margin="0,0,8,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="22" Margin="0,0,0,6"/>
                        <TextBlock x:Name="VersionCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="已安装版本" FontSize="11" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource iOS26.GlassCard}" Margin="8,0,8,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="☕" FontSize="22" Margin="0,0,0,6"/>
                        <TextBlock x:Name="JavaStatusText" Text="未检测" FontSize="16" FontWeight="Bold" Foreground="#FFC107"/>
                        <TextBlock Text="Java 运行时" FontSize="11" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource iOS26.GlassCard}" Margin="8,0,8,0" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="🧩" FontSize="22" Margin="0,0,0,6"/>
                        <TextBlock x:Name="ModCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="已安装 Mod" FontSize="11" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource iOS26.GlassCard}" Margin="8,0,0,0" Padding="16,14" Cursor="Hand" MouseLeftButtonDown="OpenLogFolder_Click">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="22" Margin="0,0,0,6"/>
                        <TextBlock Text="查看日志" FontSize="16" FontWeight="Bold" Foreground="#00E676"/>
                        <TextBlock Text="点击打开" FontSize="11" Foreground="#80FFFFFF" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource iOS26.GlassCard}" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="⚡ 快速操作" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>
                        <Button Content="📂 打开游戏目录" Click="OpenGameDir_Click" Style="{StaticResource iOS26.CapsuleButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8" HorizontalContentAlignment="Center"/>
                        <Button Content="📂 打开 Mods 文件夹" Click="OpenModsDir_Click" Style="{StaticResource iOS26.CapsuleButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8" HorizontalContentAlignment="Center"/>
                        <Button Content="📋 打开日志文件" Click="OpenLogFolder_Click" Style="{StaticResource iOS26.CapsuleButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource iOS26.GlassCard}" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="🎮 版本列表" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,12"/>
                        <ListBox x:Name="VersionListBox" Background="Transparent" BorderThickness="0" MaxHeight="180"
                                 SelectionChanged="VersionListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🧊" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Id}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="#80FFFFFF"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#25FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>