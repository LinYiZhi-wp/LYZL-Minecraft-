# Phase 9: iOS 26 磨砂玻璃大重构 — Walkthrough

**0 errors · 4批次全部完成 · 13个文件修改**

---

## 批次A: 视觉基础层

### 玻璃材质层级
```diff:iOS26.xaml
===
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- iOS 26 磨砂玻璃层级（从实心黑进化为通透感） -->
    <SolidColorBrush x:Key="iOS26.Background" Color="#40000000"/>               <!-- 25% 黑 - 最底层，透出壁纸 -->
    <SolidColorBrush x:Key="iOS26.SidebarLayer" Color="#4D101014"/>             <!-- 30% 侧边栏 - 极通透 -->
    <SolidColorBrush x:Key="iOS26.ContentLayer" Color="#80181820"/>             <!-- 50% 内容区 - 半透明 -->
    <SolidColorBrush x:Key="iOS26.FloatingLayer" Color="#B0202028"/>            <!-- 69% 弹出层 - 略深 -->
    <SolidColorBrush x:Key="iOS26.CardLayer" Color="#30FFFFFF"/>                <!-- 卡片玻璃 - 白色微光 -->
    
    <!-- 强调色 -->
    <SolidColorBrush x:Key="iOS26.Accent" Color="#00E676"/>
    <SolidColorBrush x:Key="iOS26.AccentHover" Color="#00FF80"/>
    
    <!-- 圆角常量 -->
    <CornerRadius x:Key="iOS26.CornerRadius.Large">16</CornerRadius>
    <CornerRadius x:Key="iOS26.CornerRadius.Medium">12</CornerRadius>
    <CornerRadius x:Key="iOS26.CornerRadius.Small">8</CornerRadius>
    
    <!-- 阴影效果 -->
    <DropShadowEffect x:Key="iOS26.Shadow.Default" 
                      BlurRadius="30" 
                      ShadowDepth="5" 
                      Opacity="0.25" 
                      Color="Black"/>
    
    <DropShadowEffect x:Key="iOS26.Shadow.Glow" 
                      BlurRadius="60" 
                      ShadowDepth="0" 
                      Opacity="0.7" 
                      Color="#00E676"/>

    <!-- Hero按钮样式 -->
    <Style x:Key="HeroButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="80"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2ECC71" Offset="0"/>
                    <GradientStop Color="#00E676" Offset="0.4"/>
                    <GradientStop Color="#00C853" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{StaticResource iOS26.Shadow.Glow}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource iOS26.CornerRadius.Large}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ButtonScale"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="1.02" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="1.02" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="1.0" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="1.0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="0.98" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="0.98" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- iOS卡片样式 -->
    <Style x:Key="iOS26.CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource iOS26.ContentLayer}"/>
        <Setter Property="CornerRadius" Value="{StaticResource iOS26.CornerRadius.Large}"/>
        <Setter Property="Effect" Value="{StaticResource iOS26.Shadow.Default}"/>
    </Style>

    <!-- NavigationViewItem 果冻动画样式 -->
    <Style x:Key="JellyNavItemStyle" TargetType="{x:Type ContentPresenter}">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform x:Name="NavItemScale" ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1.05" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1.05" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                           To="1.0" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                           To="1.0" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- iOS分段控制器样式 (RadioButton) -->
    <Style x:Key="SegmentRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#80FFFFFF"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#40FFFFFF"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- iOS Settings Group Style -->
    <Style x:Key="iOS26.SettingsGroup" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource iOS26.ContentLayer}"/>
        <Setter Property="CornerRadius" Value="{StaticResource iOS26.CornerRadius.Large}"/>
        <Setter Property="Margin" Value="0,0,0,24"/>
        <Setter Property="Padding" Value="0"/> <!-- Items handle padding -->
        <Setter Property="Effect" Value="{StaticResource iOS26.Shadow.Default}"/>
    </Style>

    <!-- iOS Settings Item Container (Row) -->
    <Style x:Key="iOS26.SettingsItem" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- iOS Settings Item Title -->
    <Style x:Key="iOS26.SettingsItem.Title" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <!-- iOS Settings Item Value (Right side) -->
    <Style x:Key="iOS26.SettingsItem.Value" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="#80FFFFFF"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="Margin" Value="10,0,0,0"/>
    </Style>
    
    <!-- iOS Settings Section Header -->
    <Style x:Key="iOS26.SettingsSectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#80FFFFFF"/>
        <Setter Property="Margin" Value="16,0,0,8"/>
    </Style>

    <!-- ============================================ -->
    <!-- iOS26 扩展样式: 玻璃卡片, 二级按钮, 果冻动画 -->
    <!-- ============================================ -->

    <!-- 玻璃效果卡片 (Glassmorphism) -->
    <Style x:Key="iOS26.GlassCard" TargetType="Border">
        <Setter Property="Background" Value="#25FFFFFF"/>
        <Setter Property="BorderBrush" Value="#30FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource iOS26.CornerRadius.Large}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect" Value="{StaticResource iOS26.Shadow.Default}"/>
    </Style>

    <!-- 悬浮卡片 (带 hover 放大效果) -->
    <Style x:Key="iOS26.HoverCard" TargetType="Border">
        <Setter Property="Background" Value="#40252525"/>
        <Setter Property="BorderBrush" Value="#60FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource iOS26.CornerRadius.Large}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TransformGroup>
                    <ScaleTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 二级按钮 (半透明, 用于次要操作) -->
    <Style x:Key="iOS26.SecondaryButton" TargetType="Button">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="20,0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#30FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource iOS26.CornerRadius.Medium}"
                            Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BtnScale"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="0.95" Duration="0:0:0.08"/>
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="0.95" Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BtnScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 果冻按压按钮 (弹性回弹效果, 用于任意 Button) -->
    <Style x:Key="iOS26.JellyButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource iOS26.CornerRadius.Medium}"
                            Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="JellyScale"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Jelly press: scale down then spring back -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="JellyScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="0.92" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="JellyScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="0.92" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="JellyScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="1.0" Duration="0:0:0.35">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="JellyScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="1.0" Duration="0:0:0.35">
                                            <DoubleAnimation.EasingFunction>
                                                <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!--          页面转场动画 Storyboards            -->
    <!-- ============================================ -->

    <!-- 页面淡入 + 上滑 (用于 Page.Loaded) -->
    <Storyboard x:Key="iOS26.PageSlideIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                       From="0" To="1" Duration="0:0:0.4">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                       From="40" To="0" Duration="0:0:0.5">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 页面淡入 + 缩放 (弹性效果) -->
    <Storyboard x:Key="iOS26.PageZoomIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                       From="0" To="1" Duration="0:0:0.3"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                       From="0.95" To="1.0" Duration="0:0:0.4">
            <DoubleAnimation.EasingFunction>
                <BackEase EasingMode="EaseOut" Amplitude="0.2"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                       From="0.95" To="1.0" Duration="0:0:0.4">
            <DoubleAnimation.EasingFunction>
                <BackEase EasingMode="EaseOut" Amplitude="0.2"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- ============================================ -->
    <!--              文本样式                         -->
    <!-- ============================================ -->

    <Style x:Key="iOS26.Text.Title" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style x:Key="iOS26.Text.Subtitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="#B0FFFFFF"/>
    </Style>

    <Style x:Key="iOS26.Text.Body" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#90FFFFFF"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="iOS26.Text.Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#60FFFFFF"/>
    </Style>

    <!-- 徽章样式 -->
    <Style x:Key="iOS26.Badge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource iOS26.Accent}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

</ResourceDictionary>
```

| 层级 | 旧值 | 新值 | 用途 |
|------|------|------|------|
| Background | `#99000000` (60%) | `#40000000` (25%) | 最底层，透出壁纸 |
| SidebarLayer | — | `#4D101014` (30%) | 侧边栏，极通透 |
| ContentLayer | `#CC1A1A1A` (80%) | `#80181820` (50%) | 内容区，半透明 |
| FloatingLayer | `#F21A1A1A` (95%) | `#B0202028` (69%) | 弹出层 |
| CardLayer | — | `#30FFFFFF` | 白色微光卡片 |

### 自定义滚动条
- [GlassScrollBar.xaml](file:///C:/Users/Linyizhi/.gemini/GeminiLauncher/Styles/GlassScrollBar.xaml) — 6px thin, `#40FFFFFF` thumb, hover→10px + brighter
- 全局注册在 [App.xaml](file:///C:/Users/Linyizhi/.gemini/GeminiLauncher/App.xaml)

### HeroButton 宝石渐变
`LinearGradientBrush`: `#2ECC71` → `#00E676` → `#00C853`，发光 BlurRadius 60

### 主窗口悬浮感
```diff:MainWindow.xaml
===
<ui:FluentWindow x:Class="GeminiLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:GeminiLauncher"
        xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
        xmlns:controls="clr-namespace:GeminiLauncher.Controls"
        mc:Ignorable="d"
        Title="LinLaunch" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cirno Background -->
        <Image Grid.RowSpan="2" Source="Assets/cirno_bg.png" Stretch="UniformToFill" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
        
        <!-- iOS 26 Background Layer (60% transparent) -->
        <Rectangle Grid.RowSpan="2" Fill="{StaticResource iOS26.Background}" IsHitTestVisible="False" />

        <!-- Window Controls -->
        <ui:TitleBar Grid.Row="0" Title="LinLaunch" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Floating Sidebar (Capsule) -->
            <Border Grid.Column="0" 
                    Margin="16,16,8,16" 
                    CornerRadius="20"
                    Background="{StaticResource iOS26.SidebarLayer}"
                    Effect="{StaticResource iOS26.Shadow.Default}">
                <ui:NavigationView x:Name="RootNavigation"
                                   PaneDisplayMode="Left"
                                   IsPaneOpen="True"
                                   OpenPaneLength="250"
                                   MinWidth="250"
                                   Background="Transparent"
                                   Foreground="White"
                                   IsBackButtonVisible="Visible"
                                   BackRequested="RootNavigation_BackRequested"
                                   SelectionChanged="RootNavigation_SelectionChanged"
                                   ItemInvoked="RootNavigation_ItemInvoked">
                    <ui:NavigationView.PaneHeader>
                        <StackPanel VerticalAlignment="Center" Margin="20,20,0,20">
                             <!-- Logo / Title -->
                             <TextBlock Text="LinLaunch" FontSize="24" FontWeight="Bold" 
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                             <TextBlock Text="iOS 26 Edition" FontSize="12" Opacity="0.6" />
                        </StackPanel>
                    </ui:NavigationView.PaneHeader>

                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem Content="Home" Icon="{ui:SymbolIcon Home24}" Tag="home" PreviewMouseLeftButtonDown="NavItem_Click" />
                        <ui:NavigationViewItem Content="Resources" Icon="{ui:SymbolIcon Library24}" Tag="resources" PreviewMouseLeftButtonDown="NavItem_Click" />
                        <ui:NavigationViewItem Content="Download" Icon="{ui:SymbolIcon ArrowDownload24}" Tag="download" PreviewMouseLeftButtonDown="NavItem_Click" />
                    </ui:NavigationView.MenuItems>

                    <ui:NavigationView.FooterMenuItems>
                        <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings24}" Tag="settings" PreviewMouseLeftButtonDown="NavItem_Click" />
                    </ui:NavigationView.FooterMenuItems>
                </ui:NavigationView>
            </Border>

            <!-- Manual Frame (restored) -->
            <Border Grid.Column="1" Background="Transparent" Margin="8,16,16,16"
                    CornerRadius="16" ClipToBounds="True">
                <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden" Background="Transparent"/>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
```

