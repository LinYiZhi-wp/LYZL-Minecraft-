<Page x:Class="GeminiLauncher.Views.DownloadPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:GeminiLauncher.Views"
      xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
      xmlns:conv="clr-namespace:GeminiLauncher.Converters"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="800"
      Title="下载中心"
      Background="Transparent">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:StringMatchToBoolConverter x:Key="StringMatchToBoolConverter"/>
    </Page.Resources>

    <Page.DataContext>
        <vm:DownloadViewModel/>
    </Page.DataContext>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="32,32,32,0">
            <StackPanel>
                <TextBlock Text="{DynamicResource Download_Title}" Style="{StaticResource iOS26.PageTitle}"/>
                <TextBlock Text="Browse and download game versions" Style="{StaticResource iOS26.PageSubtitle}" Margin="0,0,0,20"/>
            </StackPanel>

            <Button Content="{DynamicResource Download_ViewProgress}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,0,0,20"
                    Style="{StaticResource iOS26.CapsuleButton}"
                    Click="OpenDownloadManager_Click"/>
        </Grid>

        <StackPanel Grid.Row="0" Margin="32,110,32,0">

            <Border Background="#15FFFFFF" CornerRadius="16" Padding="5" HorizontalAlignment="Left" Width="400"
                    BorderBrush="#20FFFFFF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <RadioButton Grid.Column="0" Content="{DynamicResource Download_Filter_Release}"
                                 Style="{StaticResource SegmentRadioButtonStyle}"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Release}"
                                 Command="{Binding SwitchFilterCommand}" CommandParameter="Release"/>

                    <RadioButton Grid.Column="1" Content="{DynamicResource Download_Filter_Snapshot}"
                                 Style="{StaticResource SegmentRadioButtonStyle}"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Snapshot}"
                                 Command="{Binding SwitchFilterCommand}" CommandParameter="Snapshot"/>

                    <RadioButton Grid.Column="2" Content="{DynamicResource Download_Filter_Old}"
                                 Style="{StaticResource SegmentRadioButtonStyle}"
                                 IsChecked="{Binding SelectedFilter, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=Old}"
                                 Command="{Binding SwitchFilterCommand}" CommandParameter="Old"/>
                </Grid>
            </Border>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource iOS26.SearchBox}"
                         Height="44"/>

                <ComboBox Grid.Column="1"
                          Width="130" Height="44" Margin="10,0,0,0"
                          ItemsSource="{Binding DownloadSources}"
                          SelectedItem="{Binding SelectedSource}"
                          Style="{StaticResource iOS26.GlassComboBox}"/>
            </Grid>
        </StackPanel>

        <Border Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                Margin="32,10,32,0">
            <ProgressBar Style="{StaticResource iOS26.GlassProgressBar}" IsIndeterminate="True"/>
        </Border>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding VersionsView}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Padding="32,8,32,32">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="16"
                                        Padding="18,14"
                                        Margin="0,0,0,6"
                                        BorderBrush="#15FFFFFF"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ItemScale"/>
                                    </Border.RenderTransform>
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#18FFFFFF"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#25FFFFFF"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ItemScale"
                                                                   Storyboard.TargetProperty="ScaleX"
                                                                   To="1.005" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetName="ItemScale"
                                                                   Storyboard.TargetProperty="ScaleY"
                                                                   To="1.005" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ItemScale"
                                                                   Storyboard.TargetProperty="ScaleX"
                                                                   To="1.0" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetName="ItemScale"
                                                                   Storyboard.TargetProperty="ScaleY"
                                                                   To="1.0" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#3000E676"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Id}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Opacity="0.5" Margin="0,2,0,0">
                                <TextBlock Text="{Binding DisplayType}"
                                           FontSize="12"
                                           Foreground="White"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding ReleaseTime, StringFormat=yyyy-MM-dd}"
                                           FontSize="12"
                                           Foreground="White"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="{DynamicResource Download_DownloadButton}"
                                Style="{StaticResource iOS26.DownloadButton}"
                                Command="{Binding DataContext.DownloadVersionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>
