## 批次D: 隐私与账号

### 隐私模式 + Token 状态
```diff:SettingsPage.xaml
===
<Page x:Class="GeminiLauncher.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:GeminiLauncher.Views"
      xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Settings"
      Background="Transparent">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30" MaxWidth="800">
            <StackPanel>
                <!-- Header -->
                <TextBlock Text="{DynamicResource Settings_Title}" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="White"
                           Margin="0,0,0,10"/>
                <TextBlock Text="{DynamicResource Settings_Subtitle}" 
                           FontSize="14" 
                           Foreground="#B0FFFFFF"
                           Margin="0,0,0,30"/>

                <!-- GAME ENVIRONMENT -->
                <TextBlock Text="GAME ENVIRONMENT" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Game Path -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" 
                                Background="Transparent" 
                                Cursor="Hand" 
                                MouseLeftButtonDown="BrowseGamePath_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📁" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Settings_GamePath}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="1" 
                                           x:Name="GamePathBox" 
                                           Text="C:\..." 
                                           Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                
                                <!-- Chevron -->
                                <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#60FFFFFF" Margin="10,0,0,4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Version Isolation -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📦" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Settings_VersionIsolation}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                
                                <ui:ToggleSwitch x:Name="VersionIsolationToggle" Grid.Column="1" IsChecked="False" Checked="VersionIsolationToggle_Changed" Unchecked="VersionIsolationToggle_Changed"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- JAVA SETTINGS -->
                <TextBlock Text="JAVA SETTINGS" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Java Path -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" 
                                Background="Transparent" 
                                Cursor="Hand" 
                                MouseLeftButtonDown="BrowseJavaPath_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="☕" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Java Runtime" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock x:Name="JavaVersionText" Text="Select Java..." FontSize="13" Foreground="#00E676" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="JavaPathBox" Text="" FontSize="11" Foreground="#60FFFFFF" TextTrimming="CharacterEllipsis" MaxWidth="300" HorizontalAlignment="Right"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#60FFFFFF" Margin="10,0,0,4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Auto Search -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" 
                                BorderThickness="0" 
                                Background="Transparent" 
                                Cursor="Hand"
                                MouseLeftButtonDown="AutoSearchJava_Click">
                            <Grid>
                                 <TextBlock Text="Auto-Detect Java" Style="{StaticResource iOS26.SettingsItem.Title}" Foreground="{StaticResource iOS26.Accent}"/>
                                 <TextBlock Text="Scan System" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- MEMORY ALLOCATION -->
                <TextBlock Text="MEMORY ALLOCATION" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Mode -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Allocation Mode" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Background="#20000000" VerticalAlignment="Center">
                                    <Border CornerRadius="8" Background="#20FFFFFF" Padding="2">
                                        <StackPanel Orientation="Horizontal">
                                             <RadioButton Content="Auto" IsChecked="True" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="MemMode"/>
                                             <RadioButton Content="Custom" x:Name="CustomMemoryRadio" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="MemMode"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Slider Row -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0" MinHeight="80">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Amount" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock x:Name="MemoryValueText" Text="4096 MB" Style="{StaticResource iOS26.SettingsItem.Value}" FontWeight="Bold" Foreground="White"/>
                                </Grid>
                                
                                <Slider Grid.Row="1"
                                       x:Name="MemorySlider"
                                       Minimum="1024"
                                       Maximum="16384"
                                       Value="4096"
                                       TickFrequency="512"
                                       IsSnapToTickEnabled="True"
                                       ValueChanged="MemorySlider_ValueChanged"/>
                                
                                <!-- Memory Warning -->
                                <TextBlock x:Name="MemoryWarningText"
                                           Grid.Row="1"
                                           Text=""
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           VerticalAlignment="Bottom"
                                           Opacity="0.85"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ACCOUNTS -->
                <TextBlock Text="ACCOUNTS" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Account List (Placeholder for now, usually needs ItemsControl) -->
                        <ItemsControl ItemsSource="{Binding AccountManager.Accounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                     <Border Style="{StaticResource iOS26.SettingsItem}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Avatar placeholder -->
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="#40FFFFFF" Margin="0,0,12,0">
                                                <TextBlock Text="👤" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Username}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                                <TextBlock Text="{Binding Type}" FontSize="12" Foreground="#80FFFFFF"/>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="2" Text="Current" Foreground="#00E676" VerticalAlignment="Center" 
                                                       Visibility="{Binding Path=IsSelected, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                     </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add Account Row -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ui:TextBox x:Name="OfflineUsernameBox" 
                                           PlaceholderText="Offline Username"
                                           Width="200" 
                                           HorizontalAlignment="Left"
                                           Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                     <Button Content="Add Offline" Click="AddOfflineAccount_Click" Margin="0,0,8,0" Padding="12,6"/>
                                     <Button Content="Microsoft" Click="AddMicrosoftAccount_Click" Padding="12,6" Background="{StaticResource iOS26.Accent}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Privacy Mode -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔒" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="隐私模式" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                        <TextBlock Text="不保存登录信息（网吧模式）" FontSize="11" Opacity="0.5" Foreground="White"/>
                                    </StackPanel>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="PrivacyModeToggle" Grid.Column="1" IsChecked="False"/>
                            </Grid>
                        </Border>

                        <!-- Token Status -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔑" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Token 状态" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                <TextBlock x:Name="TokenStatusText" Grid.Column="1" Text="未登录" FontSize="12" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                
                 <!-- LANGUAGE & ABOUT -->
                <TextBlock Text="GENERAL" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Language -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Language" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton x:Name="EnglishRadio" Content="English" IsChecked="True" GroupName="Lang" Checked="Language_Changed" Margin="0,0,10,0"/>
                                    <RadioButton x:Name="ChineseRadio" Content="中文" GroupName="Lang" Checked="Language_Changed"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Check Update -->
                         <Button Command="{Binding CheckUpdateCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                             <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0" Background="Transparent">
                                        <Grid>
                                             <TextBlock Text="Check for Updates" Style="{StaticResource iOS26.SettingsItem.Title}" Foreground="{StaticResource iOS26.Accent}"/>
                                             <TextBlock Text="v1.0.0" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
```

- 🔒 隐私模式 ToggleSwitch（网吧模式）
- 🔑 Token 状态显示

