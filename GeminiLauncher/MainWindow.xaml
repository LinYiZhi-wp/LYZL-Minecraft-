<ui:FluentWindow x:Class="GeminiLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:GeminiLauncher"
        xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
        xmlns:controls="clr-namespace:GeminiLauncher.Controls"
        xmlns:views="clr-namespace:GeminiLauncher.Views"
        mc:Ignorable="d"
        Title="LYZL" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image Grid.RowSpan="2"
               Source="{Binding BackgroundImage}"
               Stretch="UniformToFill"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False">
            <Image.Effect>
                <BlurEffect Radius="{Binding BlurEffectRadius}" KernelType="Gaussian"/>
            </Image.Effect>
        </Image>

        <Rectangle Grid.RowSpan="2"
                   Fill="{StaticResource iOS26.Background}"
                   Opacity="{Binding BackgroundOpacity}"
                   IsHitTestVisible="False" />

        <ui:TitleBar Grid.Row="0" Title="{DynamicResource App_Title}" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="12,8,6,12"
                    CornerRadius="24"
                    Background="{StaticResource iOS26.SidebarLayer}"
                    BorderBrush="#20FFFFFF"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGlobalResourcesOverlayActive}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ui:NavigationView x:Name="RootNavigation"
                                   PaneDisplayMode="Left"
                                   IsPaneToggleVisible="False"
                                   IsPaneOpen="True"
                                   OpenPaneLength="240"
                                   MinWidth="240"
                                   Background="Transparent"
                                   Foreground="White"
                                   IsBackButtonVisible="Collapsed"
                                   BackRequested="RootNavigation_BackRequested"
                                   SelectionChanged="RootNavigation_SelectionChanged"
                                   ItemInvoked="RootNavigation_ItemInvoked">
                    <ui:NavigationView.PaneHeader>
                        <StackPanel VerticalAlignment="Center" Margin="24,24,0,16">
                             <TextBlock Text="LYZL" FontSize="22" FontWeight="Bold"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                             <TextBlock Text="Liquid Glass" FontSize="11" Opacity="0.5" Margin="0,2,0,0"/>
                        </StackPanel>
                    </ui:NavigationView.PaneHeader>

                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem Content="Home" Icon="{ui:SymbolIcon Home24}" Tag="home" PreviewMouseLeftButtonDown="NavItem_Click" />
                        <ui:NavigationViewItem Content="Resources" Icon="{ui:SymbolIcon Library24}" Tag="resources" PreviewMouseLeftButtonDown="NavItem_Click" />
                        <ui:NavigationViewItem Content="Download" Icon="{ui:SymbolIcon ArrowDownload24}" Tag="download" PreviewMouseLeftButtonDown="NavItem_Click" />
                    </ui:NavigationView.MenuItems>

                    <ui:NavigationView.FooterMenuItems>
                        <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings24}" Tag="settings" PreviewMouseLeftButtonDown="NavItem_Click" />
                    </ui:NavigationView.FooterMenuItems>
                </ui:NavigationView>
            </Border>

            <Border x:Name="FrameContainer" Grid.Column="1" Background="Transparent" Margin="6,8,12,12"
                    CornerRadius="24" ClipToBounds="False"
                    RenderTransformOrigin="0.5,0.5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGlobalResourcesOverlayActive}" Value="True">
                                <Setter Property="Grid.Column" Value="0"/>
                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="CornerRadius" Value="0"/>
                                <Setter Property="Panel.ZIndex" Value="1000"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border CornerRadius="24" ClipToBounds="True">
                    <Frame x:Name="RootFrame" NavigationUIVisibility="Hidden" Background="Transparent"
                           HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                           HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
                </Border>
            </Border>
        </Grid>

        <StackPanel x:Name="NotificationContainer"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,60,20,0"
                    Panel.ZIndex="2000"
                    Width="360"/>

        <views:DownloadManagerPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Panel.ZIndex="1000"/>

        <Grid x:Name="PreloadNotification" Grid.RowSpan="2" Panel.ZIndex="3000"
              VerticalAlignment="Bottom" HorizontalAlignment="Right"
              Margin="0,0,24,80"
              Visibility="Collapsed"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <TranslateTransform X="0" Y="0"/>
                </TransformGroup>
            </Grid.RenderTransform>
            <Border CornerRadius="14" Background="#C8181818" BorderBrush="#20FFFFFF" BorderThickness="1" Padding="16,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="PreloadNotifIcon" Width="24" Height="24" CornerRadius="8" Background="#2000E676" Margin="0,0,10,0">
                        <TextBlock x:Name="PreloadNotifIconText" Text="⏳" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PreloadNotifTitle" Text="正在预加载资源..." FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="PreloadNotifDetail" Text="" FontSize="10" Foreground="#70FFFFFF" Margin="0,1,0,0"/>
                    </StackPanel>
                    <ProgressBar x:Name="PreloadNotifProgress" Width="60" Height="3" Background="#20FFFFFF" Foreground="#00E676"
                                 BorderThickness="0" VerticalAlignment="Center" Margin="12,0,0,0" Maximum="100" Minimum="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
