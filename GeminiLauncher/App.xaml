<Application x:Class="GeminiLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:GeminiLauncher.Converters"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />

                <ResourceDictionary Source="Resources/Languages/en-US.xaml"/>

                <ResourceDictionary Source="Styles/iOS26.xaml"/>
                <ResourceDictionary Source="Styles/GlassScrollBar.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="SystemAccentColor">#00E676</Color>
            <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{StaticResource SystemAccentColor}"/>
            <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource SystemAccentColor}"/>
            <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="#00C853"/>
            <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="#69F0AE"/>

            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="White"/>
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#CCFFFFFF"/>
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="#80FFFFFF"/>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style TargetType="{x:Type ui:Card}">
                <Setter Property="Background" Value="#18000000"/>
                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

            <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="BorderBrush" Value="#25FFFFFF"/>
                <Setter Property="Background" Value="#18FFFFFF"/>
                <Setter Property="Foreground" Value="White"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#30FFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type ui:NavigationViewItem}">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="0,2"/>
            </Style>

            <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource iOS26.GlassTextBox}"/>

            <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource iOS26.GlassComboBox}"/>

            <Style TargetType="{x:Type ProgressBar}" BasedOn="{StaticResource iOS26.GlassProgressBar}"/>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:StringMatchToBoolConverter x:Key="StringMatchToBoolConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
