<Page x:Class="GeminiLauncher.Views.ResourcesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
      xmlns:conv="clr-namespace:GeminiLauncher.Converters"
      xmlns:ctrl="clr-namespace:GeminiLauncher.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Resources"
      Background="Transparent">

    <Page.DataContext>
        <vm:ResourcesViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:CategoryNameConverter x:Key="CategoryNameConverter"/>
        <conv:StringMatchToBoolConverter x:Key="StringMatchToBoolConverter"/>
        <conv:DownloadCountConverter x:Key="DownloadCountConverter"/>

        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.4"
                           DecelerationRatio="0.7"/>
        </Storyboard>

        <Storyboard x:Key="SkeletonPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0.25" To="0.55" Duration="0:0:1.5"
                           AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ContentFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.5"
                           DecelerationRatio="0.6"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                           From="12" To="0" Duration="0:0:0.5"
                           DecelerationRatio="0.6"/>
        </Storyboard>

        <Style x:Key="ResourceCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#1C1C26"/>
            <Setter Property="BorderBrush" Value="#12FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="-3" Duration="0:0:0.22">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#30FFFFFF" Duration="0:0:0.22"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.22"/>
                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#12FFFFFF" Duration="0:0:0.22"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FeaturedCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#1C1C26"/>
            <Setter Property="BorderBrush" Value="#12FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="-4" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#35FFFFFF" Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.25"/>
                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#12FFFFFF" Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryToggle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="indicator" Width="3" Height="18" Background="#00E676" CornerRadius="2" Margin="0,0,12,0" Visibility="Hidden"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0DFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter TargetName="indicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CollapsedCategoryToggle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#12FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#00E676"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Page.Triggers>
        <EventTrigger RoutedEvent="Page.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}"/>
        </EventTrigger>
    </Page.Triggers>

    <Grid>
        <!-- DASHBOARD LAYER -->
        <Grid x:Name="DashboardLayer">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullPageView}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="0.94" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="0.94" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)" To="-20" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.4" Duration="0:0:0.3"/>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.35">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Hidden}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.35"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.45">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.45">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)" To="0" Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.2"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                    <TranslateTransform X="0" Y="0"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0" x:Name="SidebarBorder"
                    Background="{DynamicResource iOS26.SidebarLayer}"
                    CornerRadius="0,18,18,0"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Left">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Width" Value="56"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="56" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Width" To="200" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <!-- EXPANDED SIDEBAR -->
                    <StackPanel x:Name="SidebarContent" Margin="16,20,16,20">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.1">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" BeginTime="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="资源管理" FontSize="18" FontWeight="Bold" Foreground="White" Margin="12,0,0,16"/>

                        <ToggleButton IsChecked="{Binding IsSidebarCollapsed}" Margin="0,0,0,16"
                                      Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="12,8"
                                      HorizontalAlignment="Left">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="◀" FontSize="11" VerticalAlignment="Center" Foreground="#B0FFFFFF"/>
                                            <TextBlock Text="收起" FontSize="13" Foreground="#B0FFFFFF" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#0DFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <RadioButton Content="🧩  Mod" Style="{StaticResource CategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=mod}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="mod"/>
                        <RadioButton Content="📦  整合包" Style="{StaticResource CategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=modpack}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="modpack"/>
                        <RadioButton Content="🖼️  资源包" Style="{StaticResource CategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=resourcepack}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="resourcepack"/>
                        <RadioButton Content="☀️  光影包" Style="{StaticResource CategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=shader}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="shader"/>
                        <RadioButton Content="🏷️  数据包" Style="{StaticResource CategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=datapack}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="datapack"/>

                        <Button Command="{Binding ViewMoreCommand}" Margin="0,20,0,0"
                                Background="#12FFFFFF" Foreground="White" HorizontalAlignment="Stretch"
                                BorderThickness="0" Cursor="Hand" Height="40">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="查看全部" FontSize="13" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                            <ui:SymbolIcon Symbol="ArrowRight24" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1EFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="📦 导入整合包" Command="{Binding ImportModpackCommand}" Margin="0,8,0,0"
                                Style="{StaticResource iOS26.SecondaryButton}" HorizontalAlignment="Stretch"
                                Height="40" FontSize="13" Foreground="#00E676" Background="#1A00E676"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <!-- COLLAPSED SIDEBAR -->
                    <StackPanel x:Name="CollapsedSidebarContent" Margin="0,20,0,20" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.15">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" BeginTime="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.1">
                                                        <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <ToggleButton IsChecked="{Binding IsSidebarCollapsed}" Width="40" Height="40" Margin="0,0,0,20"
                                      Background="#18FFFFFF" Cursor="Hand" ToolTip="展开侧栏">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                        <TextBlock Text="▶" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B0FFFFFF"/>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <RadioButton Content="🧩" Style="{StaticResource CollapsedCategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=mod}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="mod" ToolTip="Mod"/>
                        <RadioButton Content="📦" Style="{StaticResource CollapsedCategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=modpack}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="modpack" ToolTip="整合包"/>
                        <RadioButton Content="🖼️" Style="{StaticResource CollapsedCategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=resourcepack}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="resourcepack" ToolTip="资源包"/>
                        <RadioButton Content="☀️" Style="{StaticResource CollapsedCategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=shader}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="shader" ToolTip="光影包"/>
                        <RadioButton Content="🏷️" Style="{StaticResource CollapsedCategoryToggle}"
                                   IsChecked="{Binding SelectedCategory, Converter={StaticResource StringMatchToBoolConverter}, ConverterParameter=datapack}"
                                   Command="{Binding SwitchCategoryCommand}" CommandParameter="datapack" ToolTip="数据包"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT CONTENT AREA -->
            <Grid x:Name="RightContentArea" Grid.Column="1" Margin="28,24,28,24" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding SelectedCategory, Converter={StaticResource CategoryNameConverter}}"
                                     FontSize="30" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock Text="从 Modrinth 仓库搜索和下载资源" FontSize="13" Foreground="#80FFFFFF"/>
                        </StackPanel>

                        <Button Grid.Column="1" VerticalAlignment="Top"
                                Content="📦 导入整合包"
                                Style="{StaticResource iOS26.CapsuleButton}"
                                Command="{Binding ImportModpackCommand}"
                                Height="40" FontSize="13"
                                Foreground="#00E676" Background="#1A00E676"/>
                    </Grid>

                    <Border Background="#14141E" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="16" Padding="14,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="15" VerticalAlignment="Center" Background="Transparent"
                                     BorderThickness="0" Foreground="#EEEEEE" CaretBrush="#00E676" Padding="4,6">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <ui:Button Grid.Column="1" Command="{Binding SearchCommand}" Content="🔍 搜索"
                                      Appearance="Secondary" Margin="6,0,0,0" Padding="18,7" FontSize="13" Foreground="#EEEEEE"/>
                        </Grid>
                    </Border>

                    <ProgressBar IsIndeterminate="{Binding IsBusy}" Height="2" Margin="0,6,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="Transparent" BorderThickness="0" Foreground="#00E676"/>
                </StackPanel>

                <!-- MAIN CONTENT -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <!-- FEATURED SECTIONS -->
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSearchResults}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.25">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <!-- SKELETON LOADING -->
                            <StackPanel Visibility="{Binding IsFeaturedLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="🔥 热门推荐" FontSize="17" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,14"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                                    <Border Width="280" Height="140" Margin="0,0,10,0" CornerRadius="14" Background="#1A1A24">
                                        <Border.Triggers><EventTrigger RoutedEvent="Border.Loaded"><BeginStoryboard Storyboard="{StaticResource SkeletonPulse}"/></EventTrigger></Border.Triggers>
