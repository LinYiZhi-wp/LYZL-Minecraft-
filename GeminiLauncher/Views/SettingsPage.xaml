<Page x:Class="GeminiLauncher.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:GeminiLauncher.Views"
      xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="900"
      Title="Settings"
      Background="Transparent">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,30" MaxWidth="800">
            <StackPanel>
                <TextBlock Text="{DynamicResource Settings_Title}" Style="{StaticResource iOS26.PageTitle}"/>
                <TextBlock Text="{DynamicResource Settings_Subtitle}" Style="{StaticResource iOS26.PageSubtitle}"/>

                <!-- GAME ENVIRONMENT -->
                <TextBlock Text="{DynamicResource Settings_Section_GameEnv}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Game Path -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" 
                                Background="Transparent" 
                                Cursor="Hand" 
                                MouseLeftButtonDown="BrowseGamePath_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📁" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Settings_GamePath}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="1" 
                                           x:Name="GamePathBox" 
                                           Text="C:\..." 
                                           Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                
                                <!-- Chevron -->
                                <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#60FFFFFF" Margin="10,0,0,4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Version Isolation -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📦" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Settings_VersionIsolation}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                
                                <ui:ToggleSwitch x:Name="VersionIsolationToggle" Grid.Column="1" IsChecked="False" Checked="VersionIsolationToggle_Changed" Unchecked="VersionIsolationToggle_Changed"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- PERSONALIZATION -->
                <TextBlock Text="{DynamicResource Settings_Section_Personalization}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Background Image -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" 
                                Background="Transparent" 
                                Cursor="Hand" 
                                MouseLeftButtonDown="BrowseBackgroundImage_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🖼️" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Settings_BackgroundImage}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding ConfigService.Settings.BackgroundImagePath, TargetNullValue=Default}" 
                                           Style="{StaticResource iOS26.SettingsItem.Value}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="300"
                                           HorizontalAlignment="Right"/>
                                           
                                <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#60FFFFFF" Margin="10,0,0,4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Opacity Slider -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                             <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource Settings_Opacity}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock Text="{Binding ElementName=OpacitySlider, Path=Value, StringFormat={}{0:P0}}" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                </Grid>
                                <Slider Grid.Row="1" x:Name="OpacitySlider" Minimum="0" Maximum="1" Value="{Binding BackgroundOpacity, Mode=TwoWay}" LargeChange="0.1" SmallChange="0.01" Style="{StaticResource iOS26.GlassSlider}"/>
                            </Grid>
                        </Border>

                        <!-- Blur Slider -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                             <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource Settings_Blur}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock Text="{Binding ElementName=BlurSlider, Path=Value, StringFormat={}{0:F0}}" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                </Grid>
                                <Slider Grid.Row="1" x:Name="BlurSlider" Minimum="0" Maximum="50" Value="{Binding BlurEffectRadius, Mode=TwoWay}" Style="{StaticResource iOS26.GlassSlider}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- DOWNLOAD SETTINGS -->
                <TextBlock Text="{DynamicResource Settings_Section_Download}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Download Source -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_DownloadSource}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                
                                <ComboBox x:Name="DownloadSourceCombo" Grid.Column="1" Width="220" SelectionChanged="DownloadSource_Changed">
                                    <ComboBoxItem Content="{DynamicResource Settings_Source_Official}" Tag="Official"/>
                                    <ComboBoxItem Content="{DynamicResource Settings_Source_BMCLAPI}" Tag="BMCLAPI"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Max Threads -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                             <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource Settings_MaxThreads}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock Text="{Binding ElementName=ThreadsSlider, Path=Value, StringFormat={}{0:F0}}" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                </Grid>
                                <Slider Grid.Row="1" x:Name="ThreadsSlider" Minimum="1" Maximum="128" Value="{Binding ConfigService.Settings.MaxDownloadThreads, Mode=TwoWay}" LargeChange="8" SmallChange="1" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="MaxThreads_ValueChanged" Style="{StaticResource iOS26.GlassSlider}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- LAUNCH SETTINGS -->
                <TextBlock Text="{DynamicResource Settings_Section_Launch}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Auto-Detect Memory Toggle -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Settings_AutoDetectMemory}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock x:Name="SystemMemoryInfoText" Text="" FontSize="12" Foreground="#80FFFFFF" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="AutoDetectMemoryToggle" Grid.Column="1" IsChecked="{Binding ConfigService.Settings.AutoDetectMemory, Mode=TwoWay}" Checked="AutoDetectMemory_Changed" Unchecked="AutoDetectMemory_Changed"/>
                            </Grid>
                        </Border>

                        <!-- Max Memory Slider -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                             <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource Settings_MaxMemory}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock Text="{Binding ElementName=MaxRamSlider, Path=Value, StringFormat={}{0:F0} MB}" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                </Grid>
                                <Slider Grid.Row="1" x:Name="MaxRamSlider" Minimum="512" Maximum="32768" Value="{Binding ConfigService.Settings.MaxRam, Mode=TwoWay}" LargeChange="512" SmallChange="256" IsSnapToTickEnabled="True" TickFrequency="256" ValueChanged="MaxRam_ValueChanged" Style="{StaticResource iOS26.GlassSlider}"/>
                            </Grid>
                        </Border>

                        <!-- Min Memory Slider -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                             <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource Settings_MinMemory}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock Text="{Binding ElementName=MinRamSlider, Path=Value, StringFormat={}{0:F0} MB}" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                </Grid>
                                <Slider Grid.Row="1" x:Name="MinRamSlider" Minimum="256" Maximum="8192" Value="{Binding ConfigService.Settings.MinRam, Mode=TwoWay}" LargeChange="256" SmallChange="128" IsSnapToTickEnabled="True" TickFrequency="128" ValueChanged="MinRam_ValueChanged" Style="{StaticResource iOS26.GlassSlider}"/>
                            </Grid>
                        </Border>

                        <!-- Launcher Visibility -->
                         <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_LauncherVisibility}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                
                                <ComboBox Grid.Column="1" Width="200" SelectedIndex="{Binding ConfigService.Settings.LauncherVisibility}" SelectionChanged="LauncherVisibility_Changed">
                                    <ComboBoxItem Content="{DynamicResource Settings_Visibility_KeepOpen}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings_Visibility_Hide}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings_Visibility_Close}"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Process Priority -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_ProcessPriority}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                
                                <ComboBox Grid.Column="1" Width="200" SelectedIndex="{Binding ConfigService.Settings.ProcessPriority}" SelectionChanged="ProcessPriority_Changed">
                                    <ComboBoxItem Content="{DynamicResource Settings_Priority_Normal}"/>
                                    <ComboBoxItem Content="{DynamicResource Settings_Priority_High}"/>
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ADVANCED LAUNCH SETTINGS -->
                <TextBlock Text="{DynamicResource Settings_Section_Advanced}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Window Title -->
                         <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_WindowTitle}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                <TextBox x:Name="WindowTitleBox" Grid.Column="1" Text="{Binding ConfigService.Settings.CustomWindowTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="AdvancedSetting_Changed"/>
                            </Grid>
                        </Border>

                        <!-- JVM Arguments -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings_JvmArgs}" Style="{StaticResource iOS26.SettingsItem.Title}" Margin="0,0,0,8"/>
                                <TextBox x:Name="JvmArgsBox" Text="{Binding ConfigService.Settings.GlobalJvmArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="AdvancedSetting_Changed" TextWrapping="Wrap" MinHeight="60" AcceptsReturn="True"/>
                            </StackPanel>
                        </Border>

                        <!-- Game Arguments -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Settings_GameArgs}" Style="{StaticResource iOS26.SettingsItem.Title}" Margin="0,0,0,8"/>
                                <TextBox x:Name="GameArgsBox" Text="{Binding ConfigService.Settings.GlobalGameArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="AdvancedSetting_Changed" TextWrapping="Wrap" MinHeight="60" AcceptsReturn="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- UI CUSTOMIZATION -->
                <TextBlock Text="{DynamicResource Settings_Section_UI}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Hide Download -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_Hide_Download}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                <CheckBox x:Name="HideDownloadCheck" Grid.Column="1" Checked="HidePage_Changed" Unchecked="HidePage_Changed" Tag="download"/>
                            </Grid>
                        </Border>

                        <!-- Hide Settings (Careful with this one!) -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_Hide_Settings}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                <CheckBox x:Name="HideSettingsCheck" Grid.Column="1" Checked="HidePage_Changed" Unchecked="HidePage_Changed" Tag="settings"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- JAVA SETTINGS -->
                <TextBlock Text="{DynamicResource Settings_Section_Java}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Java Path -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" 
                                Background="Transparent" 
                                Cursor="Hand" 
                                MouseLeftButtonDown="BrowseJavaPath_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="☕" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Settings_JavaRuntime}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock x:Name="JavaVersionText" Text="{DynamicResource Settings_SelectJavaPlaceholder}" FontSize="13" Foreground="#00E676" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="JavaPathBox" Text="" FontSize="11" Foreground="#60FFFFFF" TextTrimming="CharacterEllipsis" MaxWidth="300" HorizontalAlignment="Right"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#60FFFFFF" Margin="10,0,0,4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Auto Search -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" 
                                BorderThickness="0" 
                                Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                 <TextBlock Grid.Column="0" Text="{DynamicResource Settings_AutoDetect}" Style="{StaticResource iOS26.SettingsItem.Title}" Foreground="{StaticResource iOS26.Accent}" VerticalAlignment="Center"/>
                                 <ComboBox x:Name="JavaAutoSearchCombo" Grid.Column="1" 
                                           Width="280" HorizontalAlignment="Right"
                                           Style="{StaticResource iOS26.GlassComboBox}"
                                           DropDownOpened="JavaAutoSearchCombo_DropDownOpened"
                                           SelectionChanged="JavaAutoSearchCombo_SelectionChanged"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- MEMORY ALLOCATION -->
                <TextBlock Text="{DynamicResource Settings_Section_Memory}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Mode -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_AllocationMode}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Background="#20000000" VerticalAlignment="Center">
                                    <Border CornerRadius="8" Background="#20FFFFFF" Padding="2">
                                        <StackPanel Orientation="Horizontal">
                                             <RadioButton Content="{DynamicResource Settings_Auto}" IsChecked="True" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="MemMode"/>
                                             <RadioButton Content="{DynamicResource Settings_Custom}" x:Name="CustomMemoryRadio" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="MemMode"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Slider Row -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0" MinHeight="80">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource Settings_AllocatedMemory}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                    <TextBlock x:Name="MemoryValueText" Text="4096 MB" Style="{StaticResource iOS26.SettingsItem.Value}" FontWeight="Bold" Foreground="White"/>
                                </Grid>
                                
                                <Slider Grid.Row="1"
                                       x:Name="MemorySlider"
                                       Minimum="1024"
                                       Maximum="16384"
                                       Value="4096"
                                       TickFrequency="512"
                                       IsSnapToTickEnabled="True"
                                       IsEnabled="{Binding ElementName=CustomMemoryRadio, Path=IsChecked}"
                                       ValueChanged="MemorySlider_ValueChanged"
                                       Style="{StaticResource iOS26.GlassSlider}"/>
                                
                                <!-- Memory Warning -->
                                <TextBlock x:Name="MemoryWarningText"
                                           Grid.Row="1"
                                           Text=""
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           VerticalAlignment="Bottom"
                                           Opacity="0.85"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ACCOUNTS -->
                <TextBlock Text="{DynamicResource Settings_Section_Accounts}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Account List (Placeholder for now, usually needs ItemsControl) -->
                        <ItemsControl ItemsSource="{Binding AccountManager.Accounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                     <Border Style="{StaticResource iOS26.SettingsItem}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Avatar placeholder -->
                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="#40FFFFFF" Margin="0,0,12,0">
                                                <TextBlock Text="👤" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Username}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                                <TextBlock Text="{Binding Type}" FontSize="12" Foreground="#80FFFFFF"/>
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Current" Foreground="#00E676" VerticalAlignment="Center" Margin="0,0,10,0"
                                                           Visibility="{Binding Path=IsSelected, Converter={StaticResource BoolToVis}}"/>
                                                
                                                <Button Content="Remove" 
                                                        Click="RemoveAccount_Click" 
                                                        Tag="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Foreground="#FF5252"
                                                        Padding="8,4" FontSize="12" Cursor="Hand"/>
                                            </StackPanel>
                                        </Grid>
                                     </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add Account Row -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ui:TextBox x:Name="OfflineUsernameBox" 
                                           PlaceholderText="Offline Username"
                                           Width="200" 
                                           HorizontalAlignment="Left"
                                           Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                     <Button Content="{DynamicResource Settings_AddOffline}" Click="AddOfflineAccount_Click" Margin="0,0,8,0" Padding="12,6"/>
                                     <Button Content="{DynamicResource Settings_Microsoft}" Click="AddMicrosoftAccount_Click" Padding="12,6" Background="{StaticResource iOS26.Accent}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Privacy Mode -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔒" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Settings_PrivacyMode}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                        <TextBlock Text="{DynamicResource Settings_PrivacyDesc}" FontSize="11" Opacity="0.5" Foreground="White"/>
                                    </StackPanel>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="PrivacyModeToggle" Grid.Column="1" IsChecked="False"/>
                            </Grid>
                        </Border>

                        <!-- Token Status -->
                        <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔑" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Settings_TokenStatus}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                </StackPanel>
                                <TextBlock x:Name="TokenStatusText" Grid.Column="1" Text="-" FontSize="12" Foreground="#80FFFFFF" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
                
                 <!-- LANGUAGE & ABOUT -->
                <TextBlock Text="{DynamicResource Settings_Section_General}" Style="{StaticResource iOS26.SettingsSectionHeader}"/>
                <Border Style="{StaticResource iOS26.SettingsGroup}">
                    <StackPanel>
                        <!-- Language -->
                        <Border Style="{StaticResource iOS26.SettingsItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource Settings_Language}" Style="{StaticResource iOS26.SettingsItem.Title}"/>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton x:Name="EnglishRadio" Content="{DynamicResource Settings_English}" IsChecked="True" GroupName="Lang" Checked="Language_Changed" Margin="0,0,10,0"/>
                                    <RadioButton x:Name="ChineseRadio" Content="{DynamicResource Settings_Chinese}" GroupName="Lang" Checked="Language_Changed"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Check Update -->
                         <Button Command="{Binding CheckUpdateCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                             <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Style="{StaticResource iOS26.SettingsItem}" BorderThickness="0" Background="Transparent">
                                        <Grid>
                                             <TextBlock Text="{DynamicResource Settings_CheckUpdate}" Style="{StaticResource iOS26.SettingsItem.Title}" Foreground="{StaticResource iOS26.Accent}"/>
                                             <TextBlock Text="v1.0.0" Style="{StaticResource iOS26.SettingsItem.Value}"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
