<Page x:Class="GeminiLauncher.Views.LoaderSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:conv="clr-namespace:GeminiLauncher.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="LoaderSelectionPage">

    <Page.Resources>
        <conv:ExpandIconConverter x:Key="ExpandIconConverter"/>
        <conv:BoolToAngleConverter x:Key="BoolToAngleConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <Style x:Key="LoaderListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ItemsPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="14,6,12,6"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="Dot" Text="○" FontSize="12" Margin="0,0,8,0"
                                                       VerticalAlignment="Center" Foreground="#60FFFFFF"/>
                                            <TextBlock Text="{Binding Version}" FontSize="13"
                                                       VerticalAlignment="Center" Foreground="#C0FFFFFF"
                                                       x:Name="Ver"/>
                                            <TextBlock Text="{Binding Type}" FontSize="11" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" Foreground="#50FFFFFF"
                                                       x:Name="TypeTag"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Dot" Property="Text" Value="●"/>
                                            <Setter TargetName="Dot" Property="Foreground" Value="#00E676"/>
                                            <Setter TargetName="Ver" Property="Foreground" Value="#00E676"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="30" ShadowDepth="4" Opacity="0.3" Color="Black"/>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="32,28,32,16">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button Content="←" Style="{StaticResource iOS26.CapsuleButton}"
                            Foreground="#B0FFFFFF" Background="#10FFFFFF"
                            Width="36" Height="36" Padding="0"
                            Click="Back_Click" ToolTip="返回">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="←" FontSize="18" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <Border Width="40" Height="40" CornerRadius="12" Margin="14,0,12,0"
                            Background="#1A1A24" BorderBrush="#20FFFFFF" BorderThickness="1">
                        <TextBlock Text="⛏️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding McVersion}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{DynamicResource LoaderSelect_Subtitle}" FontSize="12" Foreground="#70FFFFFF" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Loader List -->
        <ScrollViewer Grid.Row="1" Padding="32,8,32,0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="LoaderPanel">

                <!-- Forge -->
                <Border CornerRadius="16" Background="#14141E" BorderBrush="#15FFFFFF" BorderThickness="1"
                        Margin="0,0,0,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#14141E"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A1A2A"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding ForgeExpanded}" Value="True">
                                    <Setter Property="Background" Value="#181826"/>
                                    <Setter Property="BorderBrush" Value="#3000E676"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Button Command="{Binding ToggleForgeCommand}" HorizontalAlignment="Stretch"
                                Style="{x:Null}" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="0" Margin="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Margin="18,16,18,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Text="⚒️" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Forge" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock FontSize="11" Foreground="#60FFFFFF" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsForgeLoading}" Value="True">
                                                            <Setter Property="Text" Value="获取中..."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ForgeVersions.Count}" Value="0">
                                                            <Setter Property="Text" Value="不可用"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ForgeSelectedVersion}" Value="">
                                                            <Setter Property="Text" Value="可以添加"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Text" Value="{Binding ForgeSelectedVersion}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                    <ProgressBar IsIndeterminate="True" Width="16" Height="16"
                                                 Visibility="{Binding IsForgeLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding ForgeExpanded, Converter={StaticResource ExpandIconConverter}}"
                                               FontSize="13" Foreground="#70FFFFFF" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="{Binding ForgeExpanded, Converter={StaticResource BoolToAngleConverter}}"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Grid x:Name="ForgeExpandPanel" Visibility="{Binding ForgeExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                              RenderTransformOrigin="0.5,0">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform X="0" Y="0"/>
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Border BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="4,8,4,8">
                                <ListBox ItemsSource="{Binding ForgeVersions}"
                                         SelectedItem="{Binding SelectedForgeItem}"
                                         Style="{StaticResource LoaderListBox}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Fabric -->
                <Border CornerRadius="16" Background="#14141E" BorderBrush="#15FFFFFF" BorderThickness="1"
                        Margin="0,0,0,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#14141E"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A1A2A"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding FabricExpanded}" Value="True">
                                    <Setter Property="Background" Value="#181826"/>
                                    <Setter Property="BorderBrush" Value="#3000E676"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Button Command="{Binding ToggleFabricCommand}" HorizontalAlignment="Stretch"
                                Style="{x:Null}" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="0" Margin="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Margin="18,16,18,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Text="🧵" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Fabric" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock FontSize="11" Foreground="#60FFFFFF" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFabricLoading}" Value="True">
                                                            <Setter Property="Text" Value="获取中..."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FabricVersions.Count}" Value="0">
                                                            <Setter Property="Text" Value="不可用"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FabricSelectedVersion}" Value="">
                                                            <Setter Property="Text" Value="可以添加"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Text" Value="{Binding FabricSelectedVersion}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                    <ProgressBar IsIndeterminate="True" Width="16" Height="16"
                                                 Visibility="{Binding IsFabricLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding FabricExpanded, Converter={StaticResource ExpandIconConverter}}"
                                               FontSize="13" Foreground="#70FFFFFF" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="{Binding FabricExpanded, Converter={StaticResource BoolToAngleConverter}}"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Grid x:Name="FabricExpandPanel" Visibility="{Binding FabricExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                              RenderTransformOrigin="0.5,0">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform X="0" Y="0"/>
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Border BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="4,8,4,8">
                                <ListBox ItemsSource="{Binding FabricVersions}"
                                         SelectedItem="{Binding SelectedFabricItem}"
                                         Style="{StaticResource LoaderListBox}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- OptiFine -->
                <Border CornerRadius="16" Background="#14141E" BorderBrush="#15FFFFFF" BorderThickness="1"
                        Margin="0,0,0,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#14141E"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A1A2A"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding OptifineExpanded}" Value="True">
                                    <Setter Property="Background" Value="#181826"/>
                                    <Setter Property="BorderBrush" Value="#3000E676"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Button Command="{Binding ToggleOptifineCommand}" HorizontalAlignment="Stretch"
                                Style="{x:Null}" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Padding="0" Margin="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                            <Grid Margin="18,16,18,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Text="💎" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="OptiFine" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock FontSize="11" Foreground="#60FFFFFF" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOptifineLoading}" Value="True">
                                                            <Setter Property="Text" Value="获取中..."/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OptiFineVersions.Count}" Value="0">
                                                            <Setter Property="Text" Value="不可用"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding OptifineSelectedVersion}" Value="">
                                                            <Setter Property="Text" Value="可以添加"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Text" Value="{Binding OptifineSelectedVersion}"/>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                    <ProgressBar IsIndeterminate="True" Width="16" Height="16"
                                                 Visibility="{Binding IsOptifineLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding OptifineExpanded, Converter={StaticResource ExpandIconConverter}}"
                                               FontSize="13" Foreground="#70FFFFFF" VerticalAlignment="Center">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="{Binding OptifineExpanded, Converter={StaticResource BoolToAngleConverter}}"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Grid x:Name="OptifineExpandPanel" Visibility="{Binding OptifineExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                              RenderTransformOrigin="0.5,0">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform X="0" Y="0"/>
                                </TransformGroup>
                            </Grid.RenderTransform>
                            <Border BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="4,8,4,8">
                                <ListBox ItemsSource="{Binding OptiFineVersions}"
                                         SelectedItem="{Binding SelectedOptifineItem}"
                                         Style="{StaticResource LoaderListBox}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Margin="32,16,32,32">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="📥 开始下载"
                            Style="{StaticResource iOS26.CapsuleButton}"
                            Foreground="White" Background="#00E676"
                            Height="44" FontSize="15" FontWeight="SemiBold"
                            Padding="28,0" MinWidth="160"
                            Command="{Binding StartDownloadCommand}"
                            IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Download Progress Overlay -->
        <Border Grid.RowSpan="3" Background="#C0000000"
                Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="100">
            <Border Width="380" CornerRadius="20" Background="#1C1C24"
                    BorderBrush="#25FFFFFF" BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
                </Border.RenderTransform>
                <StackPanel Margin="32,28,32,28">
                    <TextBlock Text="正在下载" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DownloadStatus}" FontSize="12" Foreground="#80FFFFFF" HorizontalAlignment="Center" Margin="0,6,0,0"/>

                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="1.0" Height="4" Margin="0,20,0,0"
                                 Background="#20FFFFFF" Foreground="#00E676">
                        <ProgressBar.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2"/>
                            </Style>
                        </ProgressBar.Resources>
                    </ProgressBar>

                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0:P0}'}"
                               FontSize="12" Foreground="#00E676" HorizontalAlignment="Center" Margin="0,8,0,0"/>

                    <Button Content="后台运行" Margin="0,16,0,0"
                            Style="{StaticResource iOS26.SecondaryButton}"
                            HorizontalAlignment="Stretch" Height="36" FontSize="13"
                            Foreground="#B0FFFFFF"
                            Click="MinimizeDownload_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
