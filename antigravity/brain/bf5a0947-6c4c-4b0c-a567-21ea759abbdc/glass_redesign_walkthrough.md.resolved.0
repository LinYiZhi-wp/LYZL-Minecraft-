## 批次B: 主页重构

### 版本中心化
```diff:HomePage.xaml
===
<Page x:Class="GeminiLauncher.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:GeminiLauncher.Views"
      xmlns:vm="clr-namespace:GeminiLauncher.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Home"
      Background="Transparent">

    <Grid>
        <!-- Grid Structure Definition -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Account Capsule -->
            <RowDefinition Height="*"/>     <!-- Center Content -->
            <RowDefinition Height="Auto"/>  <!-- Launch Button -->
        </Grid.RowDefinitions>
        
        <!-- Layer 0: Dynamic Background (Behind everything) -->
        <Border Grid.RowSpan="3">
            <!-- Placeholder: Will be replaced with Cirno image -->
            <Grid>
                <!-- Gradient background as placeholder -->
                <Rectangle>
                    <Rectangle.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#1A4A90" Offset="0"/>
                            <GradientStop Color="#0D2447" Offset="1"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                
                <!-- Ice crystal effect overlay -->
                <Rectangle Opacity="0.15">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#60B0E8" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="0.5"/>
                            <GradientStop Color="#60B0E8" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </Border>

        <!-- Account Capsule (Top Right) -->
        <Border Grid.Row="0" 
                HorizontalAlignment="Right" 
                Margin="20,20,30,0"
                CornerRadius="20"
                Background="{StaticResource iOS26.FloatingLayer}"
                Padding="12,8"
                Cursor="Hand"
                MouseLeftButtonDown="AccountCapsule_Click">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <!-- Player Head (placeholder, will be replaced with actual skin) -->
                <Border Width="32" Height="32" 
                        Background="#00E676" 
                        CornerRadius="16"
                        Margin="0,0,10,0">
                    <TextBlock Text="👤" 
                               FontSize="20" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>
                
                <!-- Player Info -->
                <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock x:Name="PlayerNameText" 
                               Text="Player" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="离线模式" 
                               FontSize="10" 
                               Opacity="0.6"
                               Foreground="White"/>
                </StackPanel>
                
                <!-- Dropdown Icon -->
                <TextBlock Text="▼" 
                           FontSize="10" 
                           VerticalAlignment="Center"
                           Foreground="White"
                           Opacity="0.6"/>
            </StackPanel>
        </Border>

        <!-- Center Content: Version Display -->
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Margin="0,0,0,100">
            
            <!-- Version Number (Hero Text) -->
            <TextBlock x:Name="VersionHeroText" 
                       Text="LinLaunch" 
                       FontSize="56" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Opacity="0.95">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="Black"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- Version Type / Loader Info -->
            <TextBlock x:Name="CurrentVersionSubtitle"
                       Text="未选择版本"
                       FontSize="16"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Opacity="0.6"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Bottom Launch Area -->
        <StackPanel Grid.Row="2" 
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Width="380"
                    Margin="0,0,0,100">
            
            <!-- Launch Button (Hero) -->
            <Grid Height="60" Margin="0,0,0,15">
                <Button x:Name="LaunchButton"
                        Command="{Binding LaunchGameCommand}"
                        Content="{DynamicResource Home_LaunchGame}"
                        Style="{StaticResource HeroButtonStyle}"
                        FontSize="20"
                        Click="LaunchButton_Click"/>
                
                <!-- Launch Progress Overlay -->
                <Border x:Name="LaunchProgressPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource iOS26.ContentLayer}"
                        CornerRadius="16">
                    <Grid>
                        <ProgressBar x:Name="LaunchProgressBar"
                                     VerticalAlignment="Bottom"
                                     Height="4"
                                     Background="Transparent"
                                     Foreground="#00E676"
                                     BorderThickness="0"/>
                        <TextBlock x:Name="LaunchStatusText" 
                                   Text="正在启动..." 
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="White"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Secondary Actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Version Selector Button -->
                <Button Grid.Column="0"
                        Content="版本选择"
                        Height="45"
                        Click="OpenVersionSelector_Click"
                        Background="#20FFFFFF"
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="15"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- 🧩 Mod Shortcut Button -->
                <Button Grid.Column="2"
                        Content="🧩"
                        Height="45" Width="50"
                        Click="OpenModManager_Click"
                        Background="#20FFFFFF"
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="20"
                        Cursor="Hand"
                        ToolTip="Mod 管理">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Version Settings Button -->
                <Button Grid.Column="4"
                        Content="版本设置"
                        Height="45"
                        Click="OpenVersionSettings_Click"
                        Background="#20FFFFFF"
                        BorderBrush="#40FFFFFF"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="15"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#30FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
```

- 中央 `VersionHeroText` 56px bold（默认 "LinLaunch"，选版后显示版本号）
- 副标题显示 `MinecraftVersion · Loader`（如 "1.20.1 · Fabric"）

### 🧩 Mod 快捷入口
```diff:HomePage.xaml.cs
===
using System.Windows;
using System.Windows.Controls;
using GeminiLauncher.ViewModels;

namespace GeminiLauncher.Views
{
    public partial class HomePage : Page
    {
        public HomePage()
        {
            InitializeComponent();
            this.DataContext = ((App)System.Windows.Application.Current).MainWindow.DataContext;
            
            // Auto login as offline player by default
            AutoLoginOffline();
        }

        private void AutoLoginOffline()
        {
            if (DataContext is MainViewModel vm)
            {
                // Default offline player name
                string defaultPlayer = "Player";
                vm.AccountManager.LoginOffline(defaultPlayer);
                
                // Update account capsule
                PlayerNameText.Text = defaultPlayer;
                
                // Enable launch button
                LaunchButton.IsEnabled = true;
            }
        }

        private void AccountCapsule_Click(object sender, System.Windows.Input.MouseButtonEventArgs e)
        {
            var border = sender as System.Windows.FrameworkElement;
            if (border == null) return;

            var menu = new ContextMenu
            {
                Style = null,
                Background = new System.Windows.Media.SolidColorBrush(
                    (System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#F0202020")!),
                BorderBrush = new System.Windows.Media.SolidColorBrush(
                    (System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#40FFFFFF")!),
                BorderThickness = new Thickness(1),
                Foreground = System.Windows.Media.Brushes.White
            };

            // Switch Account (offline)
            var switchItem = new MenuItem { Header = "🔄 切换离线账号", Foreground = System.Windows.Media.Brushes.White };
            switchItem.Click += (s, args) =>
            {
                // Simple WPF input dialog
                var dlg = new Window
                {
                    Title = "切换离线账号",
                    Width = 340, Height = 160,
                    WindowStartupLocation = WindowStartupLocation.CenterOwner,
                    Owner = Window.GetWindow(this),
                    Background = new System.Windows.Media.SolidColorBrush(
                        (System.Windows.Media.Color)System.Windows.Media.ColorConverter.ConvertFromString("#1A1A1A")!),
                    ResizeMode = ResizeMode.NoResize
                };
                var sp = new StackPanel { Margin = new Thickness(20) };
                sp.Children.Add(new TextBlock { Text = "输入玩家名:", Foreground = System.Windows.Media.Brushes.White, Margin = new Thickness(0,0,0,8) });
                var tb = new TextBox { Text = "Player", FontSize = 14, Padding = new Thickness(6,4,6,4) };
                sp.Children.Add(tb);
                var okBtn = new Button { Content = "确定", Margin = new Thickness(0,12,0,0), Padding = new Thickness(20,6,20,6), HorizontalAlignment = HorizontalAlignment.Right };
                okBtn.Click += (_, __) => { dlg.DialogResult = true; };
                sp.Children.Add(okBtn);
                dlg.Content = sp;

                if (dlg.ShowDialog() == true && !string.IsNullOrWhiteSpace(tb.Text))
                {
                    var vm = DataContext as MainViewModel;
                    vm?.AccountManager.LoginOffline(tb.Text.Trim());
                    PlayerNameText.Text = tb.Text.Trim();
                }
            };
            menu.Items.Add(switchItem);

            // Microsoft Login
            var msItem = new MenuItem { Header = "🟢 微软账号登录", Foreground = System.Windows.Media.Brushes.White };
            msItem.Click += async (s, args) =>
            {
                try
                {
                    var vm = DataContext as MainViewModel;
                    if (vm != null)
                    {
                        await vm.AccountManager.LoginMicrosoft();
                        var acc = vm.AccountManager.ActiveAccount;
                        if (acc != null)
                            PlayerNameText.Text = acc.Username;
                    }
                }
                catch (System.Exception ex)
                {
                    MessageBox.Show($"登录失败: {ex.Message}", "错误");
                }
            };
            menu.Items.Add(msItem);

            menu.Items.Add(new Separator());

            // Logout
            var logoutItem = new MenuItem { Header = "🚪 注销", Foreground = System.Windows.Media.Brushes.White };
            logoutItem.Click += (s, args) =>
            {
                var vm = DataContext as MainViewModel;
                vm?.AccountManager.Logout();
                PlayerNameText.Text = "Player";
            };
            menu.Items.Add(logoutItem);

            menu.PlacementTarget = border;
            menu.Placement = System.Windows.Controls.Primitives.PlacementMode.Bottom;
            menu.IsOpen = true;
        }

        private Models.GameVersion? _currentSelectedVersion;

        private void OpenVersionSelector_Click(object sender, RoutedEventArgs e)
        {
            var dialog = new VersionSelectorDialog
            {
                Owner = Window.GetWindow(this)
            };

            if (dialog.ShowDialog() == true && dialog.SelectedVersion != null)
            {
                _currentSelectedVersion = dialog.SelectedVersion;
                
                // Update hero text to version number
                VersionHeroText.Text = _currentSelectedVersion.DisplayName;
                
                // Build subtitle with loader info
                var subtitleParts = new System.Collections.Generic.List<string>();
                if (!string.IsNullOrEmpty(_currentSelectedVersion.MinecraftVersion))
                    subtitleParts.Add(_currentSelectedVersion.MinecraftVersion);
                if (_currentSelectedVersion.Loader != null)
                    subtitleParts.Add(_currentSelectedVersion.Loader.ToString()!);
                else
                    subtitleParts.Add("Vanilla");
                CurrentVersionSubtitle.Text = string.Join(" · ", subtitleParts);
                
                // TODO: 保存选中的版本到配置
            }
        }

        private void OpenVersionSettings_Click(object sender, RoutedEventArgs e)
        {
            if (_currentSelectedVersion == null)
            {
                MessageBox.Show("请先选择一个游戏版本", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                return;
            }

            var settingsDialog = new VersionSettingsDialog(_currentSelectedVersion)
            {
                Owner = Window.GetWindow(this)
            };
            settingsDialog.ShowDialog();
        }

        private void OpenModManager_Click(object sender, RoutedEventArgs e)
        {
            if (_currentSelectedVersion == null)
            {
                MessageBox.Show("请先选择一个游戏版本", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                return;
            }

            // Open VersionSettings dialog directly on Mods tab
            var settingsDialog = new VersionSettingsDialog(_currentSelectedVersion)
            {
                Owner = Window.GetWindow(this)
            };
            settingsDialog.ShowModsTab();
            settingsDialog.ShowDialog();
        }

        private async void LaunchButton_Click(object sender, RoutedEventArgs e)
        {
            if (_currentSelectedVersion == null)
            {
                MessageBox.Show("请先选择一个游戏版本", "提示", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            // Hide button text, show progress inside button or replace button
            LaunchButton.Visibility = Visibility.Collapsed;
            LaunchProgressPanel.Visibility = Visibility.Visible;
            
            // Simulate launch progress
            await SimulateLaunchProgress();
            
            // After launch completes, restore button
            LaunchProgressPanel.Visibility = Visibility.Collapsed;
            LaunchButton.Visibility = Visibility.Visible;
        }

        private async System.Threading.Tasks.Task SimulateLaunchProgress()
        {
            // Stage 1: Preparing
            LaunchStatusText.Text = "准备中...";
            for (int i = 0; i <= 20; i++)
            {
                LaunchProgressBar.Value = i;
                await System.Threading.Tasks.Task.Delay(50);
            }
            
            // Stage 2: Downloading assets
            LaunchStatusText.Text = "下载资源...";
            for (int i = 20; i <= 60; i++)
            {
                LaunchProgressBar.Value = i;
                await System.Threading.Tasks.Task.Delay(30);
            }
            
            // Stage 3: Verifying
            LaunchStatusText.Text = "校验文件...";
            for (int i = 60; i <= 85; i++)
            {
                LaunchProgressBar.Value = i;
                await System.Threading.Tasks.Task.Delay(40);
            }
            
            // Stage 4: Launching
            LaunchStatusText.Text = "启动中...";
            for (int i = 85; i <= 100; i++)
            {
                LaunchProgressBar.Value = i;
                await System.Threading.Tasks.Task.Delay(50);
            }
            
            await System.Threading.Tasks.Task.Delay(500);
            
            // TODO: Replace with actual launch command
            MessageBox.Show($"正在启动 {_currentSelectedVersion?.DisplayName}...", "启动", MessageBoxButton.OK, MessageBoxImage.Information);
        }
    }
}
```

- 底部三按钮布局：版本选择 / 🧩 / 版本设置
- 点击 🧩 → 直接打开 [VersionSettingsDialog](file:///C:/Users/Linyizhi/.gemini/GeminiLauncher/Views/VersionSettingsDialog.xaml.cs#13-25) 的 Mods tab

