<Window x:Class="GeminiLauncher.Views.VersionSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="版本选择" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize">
    <Window.Resources>
        <!-- Folder Panel Expand Animation -->
        <Storyboard x:Key="ExpandFolderPanel">
            <DoubleAnimation Storyboard.TargetName="FolderPanel" Storyboard.TargetProperty="Width" From="0" To="260" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="FolderPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="FolderPanelTranslate" Storyboard.TargetProperty="X" From="-20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FolderPanel" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
        <!-- Folder Panel Collapse Animation -->
        <Storyboard x:Key="CollapseFolderPanel">
            <DoubleAnimation Storyboard.TargetName="FolderPanel" Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="FolderPanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="FolderPanelTranslate" Storyboard.TargetProperty="X" To="-15" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FolderPanel" Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.3">
                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>
    
    <Border Background="{StaticResource iOS26.ContentLayer}" CornerRadius="36">
        <Border.Effect><DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="Black"/></Border.Effect>
        <Grid>
            <!-- CONTENT AREA (Layer 0, with margins for Header and Footer) -->
            <Grid Margin="20,85,20,90">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Folder Panel -->
                <Border x:Name="FolderPanel" 
                        Grid.Column="0" 
                        Width="0" 
                        Opacity="0"
                        Visibility="Collapsed"
                        Background="#25000000" 
                        CornerRadius="24" 
                        Padding="15" 
                        Margin="0,0,18,0"
                        BorderBrush="#18FFFFFF" BorderThickness="1">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="FolderPanelTranslate"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="文件夹列表" FontSize="13" FontWeight="Bold" Opacity="0.9" Foreground="White" Margin="5,5,5,18"/>
                        
                        <ListView x:Name="FoldersListView" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="FoldersListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#25FFFFFF" CornerRadius="20" Padding="14" Margin="0,0,0,10" Cursor="Hand">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.75" Foreground="#F0FFFFFF" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                        
                        <StackPanel Grid.Row="2" Margin="0,15,0,0">
                            <Button Content="+ 添加文件夹" Click="AddFolder_Click" Style="{StaticResource iOS26.SecondaryButton}" Padding="0,10" Margin="0,0,0,10" Height="42" FontSize="14"/>
                            <Button Content="📦 导入整合包" Click="ImportModpack_Click" Style="{StaticResource iOS26.SecondaryButton}" Padding="0,10" Height="42" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Versions List -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="5,0">
                    <StackPanel x:Name="VersionsPanel" Margin="0,0,5,0"/>
                </ScrollViewer>
            </Grid>

            <!-- TITLE BAR (Layer 1, Overlay Top - iOS 26 Style Floating Pill) -->
            <Border VerticalAlignment="Top" Height="64" Margin="20,20,20,0" Background="#35FFFFFF" CornerRadius="32" BorderBrush="#35FFFFFF" BorderThickness="1" Panel.ZIndex="50">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.3" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <!-- Left: Back Button -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,0,0,0">
                        <Button Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8">
                            <ui:SymbolIcon Symbol="ArrowLeft24" Foreground="White" FontSize="20"/>
                        </Button>
                    </StackPanel>

                    <!-- Center: Title -->
                    <TextBlock Text="版本选择" FontSize="19" FontWeight="Bold" Foreground="White" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               IsHitTestVisible="False" Effect="{x:Null}"/>
                    
                    <!-- Right: Actions -->
                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="ToggleFolderBtn" Grid.Column="0"
                                Content="📁 文件夹" 
                                Click="ToggleFolderPanel_Click" 
                                Padding="15,0" Height="36" MinWidth="110" FontSize="14"
                                Background="#30FFFFFF" Foreground="White" 
                                BorderBrush="#45FFFFFF" BorderThickness="1" Cursor="Hand"
                                Margin="0,0,12,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="18"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <Button Grid.Column="1" Content="×" Width="36" Height="36" FontSize="24" Background="Transparent" Foreground="White" BorderThickness="0" Click="CloseButton_Click" Cursor="Hand" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- FOOTER (Layer 2, Overlay Bottom) -->
            <Border VerticalAlignment="Bottom" Height="90" Background="#F01E1E1E" Padding="25,20" CornerRadius="0,0,36,36" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0" Panel.ZIndex="100">
                <Grid>
                    <TextBlock Text="请选择一个版本继续" VerticalAlignment="Center" Foreground="#AAFFFFFF" FontSize="14" FontStyle="Normal"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Cancel Button -->
                        <Border CornerRadius="24" Background="#30FFFFFF" Margin="0,0,15,0">
                            <Button Content="取消" Click="CloseButton_Click" 
                                    Padding="35,12" 
                                    Background="Transparent" Foreground="White" 
                                    BorderThickness="0" Cursor="Hand"/>
                        </Border>
                        
                        <!-- Confirm Button -->
                        <Border x:Name="ConfirmButtonBorder" CornerRadius="24" Background="{StaticResource iOS26.Accent}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.4" Color="#00E676"/>
                            </Border.Effect>
                            <Button x:Name="ConfirmButton" Content="确定选择" 
                                    Click="ConfirmButton_Click" 
                                    Padding="50,12" 
                                    Background="Transparent" Foreground="White" 
                                    BorderThickness="0" FontSize="16" FontWeight="Bold" 
                                    Cursor="Hand"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
