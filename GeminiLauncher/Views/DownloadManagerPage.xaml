<Page x:Class="GeminiLauncher.Views.DownloadManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:conv="clr-namespace:GeminiLauncher.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="1000"
      Title="DownloadManagerPage">

    <Page.Resources>
        <conv:ProgressToIconConverter x:Key="ProgressToIconConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="{DynamicResource iOS26.Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Statistics -->
        <Border Grid.Column="0" 
                Background="{DynamicResource iOS26.SidebarLayer}"
                BorderBrush="#10FFFFFF"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="24,60,24,20">
                <TextBlock Text="{DynamicResource DownloadManager_StatsTitle}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,40"/>

                <!-- Stat Cards -->
                <Border Background="#10FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DownloadManager_TotalProgress}" FontSize="11" Opacity="0.6" Foreground="White"/>
                        <TextBlock Text="{Binding TotalProgressText}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#10FFFFFF" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DownloadManager_Speed}" FontSize="11" Opacity="0.6" Foreground="White"/>
                        <TextBlock Text="{Binding GlobalSpeedText}" FontSize="24" FontWeight="Bold" Foreground="#00E676" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#10FFFFFF" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DownloadManager_Remaining}" FontSize="11" Opacity="0.6" Foreground="White"/>
                        <TextBlock Text="{Binding TotalRemainingFiles}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main Content (Task List) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Header -->
            <Border Grid.Row="0" Margin="30,20,30,0">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Button Style="{StaticResource iOS26.CapsuleButton}" 
                                Foreground="#B0FFFFFF" Background="#10FFFFFF"
                                Width="36" Height="36" Padding="0"
                                Click="Back_Click"
                                ToolTip="返回">
                            <TextBlock Text="←" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <TextBlock Text="{DynamicResource DownloadManager_Title}" FontSize="18" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="🔄 重试失败" 
                                Style="{StaticResource iOS26.CapsuleButton}" 
                                Foreground="#FFC107" Background="#1AFFC107"
                                Height="32" FontSize="11" Margin="6,0,4,0"
                                Click="RetryFailed_Click"/>
                        <Button Content="🗑 清除已完成" 
                                Style="{StaticResource iOS26.CapsuleButton}" 
                                Foreground="#80FFFFFF" Background="#15FFFFFF"
                                Height="32" FontSize="11" Margin="4,0,4,0"
                                Click="RemoveCompleted_Click"/>
                        <Button Content="✕ 全部取消" 
                                Style="{StaticResource iOS26.CapsuleButton}" 
                                Foreground="#FF5252" Background="#1AFF5252"
                                Height="32" FontSize="11" Margin="4,0,0,0"
                                Click="CancelAll_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Task List -->
            <ScrollViewer Grid.Row="1" Padding="30,10,30,30">
                <ItemsControl ItemsSource="{Binding ActiveTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource iOS26.CardLayer}" 
                                    CornerRadius="16" 
                                    BorderBrush="#15FFFFFF"
                                    BorderThickness="1"
                                    Padding="24"
                                    Margin="0,0,0,20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Task Name & Main Progress -->
                                    <Grid Grid.Row="0" Margin="0,0,0,20">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Games24" FontSize="24" Foreground="{DynamicResource SystemAccentColorBrush}" Margin="0,0,12,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name, StringFormat='Minecraft {0}'}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding Status}" FontSize="12" Opacity="0.6" Foreground="White"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProgressPercentageText}" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Text="{Binding SpeedText}" FontSize="11" Foreground="#00E676" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Button Content="✕" 
                                                    Style="{StaticResource iOS26.CapsuleButton}"
                                                    Foreground="#FF5252" Background="#1AFF5252"
                                                    FontSize="11" Width="30" Height="30"
                                                    VerticalAlignment="Center"
                                                    Click="CancelTask_Click"
                                                    Visibility="{Binding IsCompleted, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Main Progress Bar -->
                                    <ProgressBar Grid.Row="1" Value="{Binding Progress, Mode=OneWay}" Maximum="1.0" Height="6" Margin="0,0,0,24">
                                        <ProgressBar.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="3"/>
                                            </Style>
                                        </ProgressBar.Resources>
                                    </ProgressBar>

                                    <!-- Detailed Steps -->
                                    <UniformGrid Grid.Row="2" Columns="4">
                                        <!-- JSON -->
                                        <StackPanel Margin="0,0,15,0">
                                            <Grid>
                                                <TextBlock Text="{DynamicResource DownloadManager_Step_JSON}" FontSize="11" Opacity="0.6" Foreground="White"/>
                                                <ContentControl Content="{Binding JsonProgress, Converter={StaticResource ProgressToIconConverter}}" 
                                                               HorizontalAlignment="Right"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding JsonProgress}" Maximum="1.0" Height="3" Margin="0,6,0,4"/>
                                            <TextBlock Text="{Binding JsonStatusText}" FontSize="10" Opacity="0.5" Foreground="White"/>
                                        </StackPanel>

                                        <!-- Libs -->
                                        <StackPanel Margin="0,0,15,0">
                                            <Grid>
                                                <TextBlock Text="{DynamicResource DownloadManager_Step_Libs}" FontSize="11" Opacity="0.6" Foreground="White"/>
                                                <TextBlock Text="{Binding LibrariesProgress, StringFormat='{}{0:P0}'}" FontSize="11" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding LibrariesProgress}" Maximum="1.0" Height="3" Margin="0,6,0,4"/>
                                            <TextBlock Text="{Binding LibrariesStatusText}" FontSize="10" Opacity="0.5" Foreground="White"/>
                                        </StackPanel>

                                        <!-- Assets -->
                                        <StackPanel Margin="0,0,15,0">
                                            <Grid>
                                                <TextBlock Text="{DynamicResource DownloadManager_Step_Assets}" FontSize="11" Opacity="0.6" Foreground="White"/>
                                                <TextBlock Text="{Binding AssetsProgress, StringFormat='{}{0:P0}'}" FontSize="11" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding AssetsProgress}" Maximum="1.0" Height="3" Margin="0,6,0,4"/>
                                            <TextBlock Text="{Binding AssetsStatusText}" FontSize="10" Opacity="0.5" Foreground="White"/>
                                        </StackPanel>

                                        <!-- Loader -->
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{DynamicResource DownloadManager_Step_Install}" FontSize="11" Opacity="0.6" Foreground="White"/>
                                                <ContentControl Content="{Binding ComponentsProgress, Converter={StaticResource ProgressToIconConverter}}" 
                                                               HorizontalAlignment="Right"/>
                                            </Grid>
                                            <ProgressBar Value="{Binding ComponentsProgress}" Maximum="1.0" Height="3" Margin="0,6,0,4"/>
                                            <TextBlock Text="{Binding ComponentsStatusText}" FontSize="10" Opacity="0.5" Foreground="White"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
